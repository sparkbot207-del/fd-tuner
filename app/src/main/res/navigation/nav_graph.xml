<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/scanFragment">

    <!-- Scan screen (start) -->
    <fragment
        android:id="@+id/scanFragment"
        android:name="com.bretthalliday.fdtuner.ui.scan.ScanFragment"
        android:label="Scan"
        tools:layout="@layout/fragment_scan">

        <action
            android:id="@+id/action_scan_to_main"
            app:destination="@id/dashboardFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popUpTo="@id/scanFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <!-- Dashboard (bottom nav tab 1) -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.bretthalliday.fdtuner.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <!-- Params menu (bottom nav tab 2) -->
    <fragment
        android:id="@+id/paramsMenuFragment"
        android:name="com.bretthalliday.fdtuner.ui.params.ParamsMenuFragment"
        android:label="Parameters"
        tools:layout="@layout/fragment_params_menu">

        <action
            android:id="@+id/action_paramsMenu_to_paramsSection"
            app:destination="@id/paramsSectionFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />
    </fragment>

    <!-- Params section detail -->
    <fragment
        android:id="@+id/paramsSectionFragment"
        android:name="com.bretthalliday.fdtuner.ui.params.ParamsSectionFragment"
        android:label="Section"
        tools:layout="@layout/fragment_params_section">

        <argument
            android:name="section"
            app:argType="string"
            android:defaultValue="Parameters" />
    </fragment>

    <!-- Settings (bottom nav tab 3) -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.bretthalliday.fdtuner.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <!-- Profiles (bottom nav tab 4) -->
    <fragment
        android:id="@+id/profilesFragment"
        android:name="com.bretthalliday.fdtuner.ui.profiles.ProfilesFragment"
        android:label="Profiles"
        tools:layout="@layout/fragment_profiles" />

    <!-- Error codes (bottom nav tab 5) -->
    <fragment
        android:id="@+id/errorCodesFragment"
        android:name="com.bretthalliday.fdtuner.ui.errors.ErrorCodesFragment"
        android:label="Error Codes"
        tools:layout="@layout/fragment_error_codes" />

</navigation>
