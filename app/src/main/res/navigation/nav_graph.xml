<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/scanFragment">

    <!-- Scan screen (start) -->
    <fragment
        android:id="@+id/scanFragment"
        android:name="com.bretthalliday.fdtuner.ui.scan.ScanFragment"
        android:label="Scan"
        tools:layout="@layout/fragment_scan">

        <action
            android:id="@+id/action_scan_to_main"
            app:destination="@id/dashboardFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popUpTo="@id/scanFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <!-- Dashboard (bottom nav tab 1) -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.bretthalliday.fdtuner.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <!-- Params menu (bottom nav tab 2) -->
    <fragment
        android:id="@+id/paramsMenuFragment"
        android:name="com.bretthalliday.fdtuner.ui.params.ParamsMenuFragment"
        android:label="Parameters"
        tools:layout="@layout/fragment_params_menu">

        <action
            android:id="@+id/action_paramsMenu_to_paramsSection"
            app:destination="@id/paramsSectionFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />
    </fragment>

    <!-- Params section detail -->
    <fragment
        android:id="@+id/paramsSectionFragment"
        android:name="com.bretthalliday.fdtuner.ui.params.ParamsSectionFragment"
        android:label="Section"
        tools:layout="@layout/fragment_params_section">

        <argument
            android:name="section"
            app:argType="string"
            android:defaultValue="Parameters" />
    </fragment>

    <!-- Settings (bottom nav tab 3) -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.bretthalliday.fdtuner.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings">

        <action
            android:id="@+id/action_settings_to_sniffer"
            app:destination="@id/snifferFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />

        <action
            android:id="@+id/action_settings_to_diagnostics"
            app:destination="@id/diagnosticsFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />
    </fragment>

    <!-- Profiles (bottom nav tab 4) -->
    <fragment
        android:id="@+id/profilesFragment"
        android:name="com.bretthalliday.fdtuner.ui.profiles.ProfilesFragment"
        android:label="Profiles"
        tools:layout="@layout/fragment_profiles" />

    <!-- Error codes (bottom nav tab 5) -->
    <fragment
        android:id="@+id/errorCodesFragment"
        android:name="com.bretthalliday.fdtuner.ui.errors.ErrorCodesFragment"
        android:label="Error Codes"
        tools:layout="@layout/fragment_error_codes" />

    <!-- Packet Sniffer — dev mode only; entered from Settings -->
    <fragment
        android:id="@+id/snifferFragment"
        android:name="com.bretthalliday.fdtuner.ui.sniffer.SnifferFragment"
        android:label="Packet Sniffer"
        tools:layout="@layout/fragment_sniffer">

        <action
            android:id="@+id/action_snifferFragment_to_snifferDetailFragment"
            app:destination="@id/snifferDetailFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />

        <action
            android:id="@+id/action_snifferFragment_to_analysisFragment"
            app:destination="@id/analysisFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />
    </fragment>

    <!-- Capture Analysis — shows monospace report from CaptureAnalyzer -->
    <fragment
        android:id="@+id/analysisFragment"
        android:name="com.bretthalliday.fdtuner.ui.sniffer.AnalysisFragment"
        android:label="Capture Analysis"
        tools:layout="@layout/fragment_analysis" />

    <!-- Sniffer block detail -->
    <fragment
        android:id="@+id/snifferDetailFragment"
        android:name="com.bretthalliday.fdtuner.ui.sniffer.SnifferDetailFragment"
        android:label="Block Detail"
        tools:layout="@layout/fragment_sniffer_detail">

        <argument
            android:name="baseAddr"
            app:argType="integer"
            android:defaultValue="0" />
    </fragment>



    <!-- Diagnostics — read-only live state/telemetry; entered from Settings -->
    <fragment
        android:id="@+id/diagnosticsFragment"
        android:name="com.bretthalliday.fdtuner.ui.diagnostics.DiagnosticsFragment"
        android:label="Diagnostics"
        tools:layout="@layout/fragment_diagnostics" />

</navigation>
