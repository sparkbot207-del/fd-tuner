<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.FDTuner" parent="Theme.Material3.Dark">
        <item name="colorPrimary">@color/orange_primary</item>
        <item name="colorPrimaryVariant">@color/orange_dark</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <item name="colorSecondary">@color/orange_primary</item>
        <item name="colorOnSecondary">@color/bg_dark</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorError">@color/error_red</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="actionBarStyle">@style/Widget.FDTuner.ActionBar</item>
    </style>

    <style name="Widget.FDTuner.ActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/bg_surface</item>
        <item name="titleTextStyle">@style/TextAppearance.FDTuner.Title</item>
    </style>

    <style name="TextAppearance.FDTuner.Title" parent="TextAppearance.AppCompat.Title">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="ThemeOverlay.FDTuner.ActionBar" parent="">
        <item name="colorControlNormal">@color/text_primary</item>
    </style>

    <!-- Dialog style -->
    <style name="Theme.FDTuner.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/orange_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_surface</item>
    </style>

</resources>
