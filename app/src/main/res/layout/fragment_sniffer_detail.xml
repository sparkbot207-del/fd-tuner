<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Block header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/bg_surface"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvDetailTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Block 0x00"
            android:textColor="@color/cyan_accent"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/tvDetailSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="— words 0x00–0x05 —"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Column headers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:background="@color/bg_surface">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1.2" android:text="ADDR"
            android:textColor="@color/text_secondary" android:textSize="10sp"
            android:fontFamily="monospace" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1.5" android:text="HEX"
            android:textColor="@color/text_secondary" android:textSize="10sp"
            android:fontFamily="monospace" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1.5" android:text="DECIMAL"
            android:textColor="@color/text_secondary" android:textSize="10sp"
            android:fontFamily="monospace" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="MIN"
            android:textColor="@color/text_secondary" android:textSize="10sp"
            android:fontFamily="monospace" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="MAX"
            android:textColor="@color/text_secondary" android:textSize="10sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- 6 word rows (word 0 through word 5) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/llWordRows"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="4dp">

            <!-- Rows injected by SnifferDetailFragment (6 × item_sniffer_word) -->

        </LinearLayout>
    </ScrollView>

    <!-- Raw hex row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@color/bg_surface">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RAW HEX"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvDetailRawHex"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- --"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:fontFamily="monospace" />

    </LinearLayout>

</LinearLayout>
