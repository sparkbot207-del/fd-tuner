<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_surface">

    <!-- Handle / header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PARAM CHANGE LOG"
            android:textColor="@color/pink_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearLog"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Clear Log"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvEmptyLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No param changes recorded yet.\nEdit parameters to see the audit trail here."
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="40dp"
        android:lineSpacingMultiplier="1.4"
        android:visibility="gone" />

    <!-- Log entries -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerChangelog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="480dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp" />

</LinearLayout>
