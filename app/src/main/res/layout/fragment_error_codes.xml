<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Beep counter -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_surface"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HOW MANY BEEPS?"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBeepMinus"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="−"
                android:textSize="24sp"
                android:textColor="@color/pink_primary"
                app:strokeColor="@color/pink_primary" />

            <TextView
                android:id="@+id/tvBeepCount"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="?"
                android:textColor="@color/pink_primary"
                android:textSize="52sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="sans-serif-condensed" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBeepPlus"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="+"
                android:textSize="24sp"
                android:textColor="@color/pink_primary"
                app:strokeColor="@color/pink_primary" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBeepReset"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Clear"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap a card to expand troubleshooting steps. ★ = special beep pattern."
        android:textColor="@color/text_hint"
        android:textSize="11sp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerErrors"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="80dp" />

</LinearLayout>
