<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Header row: packet count + Export button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:gravity="center_vertical"
        android:background="@color/bg_surface">

        <TextView
            android:id="@+id/tvPacketCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Waiting for packets…"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearSession"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Clear"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnalyze"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Analyze"
            android:textColor="@color/orange_primary"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExportCsv"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Export CSV"
            android:textColor="@color/cyan_accent"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Block list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSnifferBlocks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- Annotation bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_surface"
        android:paddingHorizontal="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="10dp">

        <!-- Free-text annotation entry -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <EditText
                android:id="@+id/etAnnotation"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:hint="Annotation…"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="13sp"
                android:background="@android:color/transparent"
                android:paddingHorizontal="4dp"
                android:inputType="text"
                android:imeOptions="actionDone"
                android:maxLines="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnnotateFreeText"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Tag"
                android:textSize="11sp"
                app:strokeColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Quick-tag buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTagBrake"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="4dp"
                android:text="🛑 Brake"
                android:textSize="10sp"
                app:strokeColor="@color/error_red" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTagThrottle25"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="4dp"
                android:text="⚡ 25%"
                android:textSize="10sp"
                app:strokeColor="@color/orange_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTagThrottle50"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="4dp"
                android:text="⚡ 50%"
                android:textSize="10sp"
                app:strokeColor="@color/orange_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTagThrottle100"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="4dp"
                android:text="⚡ WOT"
                android:textSize="10sp"
                app:strokeColor="@color/orange_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTagRolling"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="4dp"
                android:text="🔄 Rolling"
                android:textSize="10sp"
                app:strokeColor="@color/cyan_accent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTagStopped"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="🛑 Stop"
                android:textSize="10sp"
                app:strokeColor="@color/text_secondary" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
